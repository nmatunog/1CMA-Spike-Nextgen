# Auth (NextAuth) — production & shared teams: set a strong value:
#   openssl rand -base64 32
# Local `npm run dev` works without this (dev-only fallback in auth.ts).
AUTH_SECRET=

# Demo login (optional — leave unset to disable matching in authorize())
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=

# Outbound: n8n workflow webhook URL (lead.created, social events)
N8N_WEBHOOK_URL=

# Optional separate URL for social automation workflows
N8N_SOCIAL_WEBHOOK_URL=

# Inbound from n8n → app/api/webhooks/n8n (optional shared secret)
N8N_INBOUND_SECRET=

# Litestream (see litestream.yml) — S3-compatible bucket
# LITESTREAM_S3_BUCKET=
# LITESTREAM_S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional: local Ollama (if OLLAMA_MODEL is set, /api/chat uses it; else stub)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# Optional: analytics (Plausible — add script in app/layout if set)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Supabase (DNA quiz + admin dashboard) — create table `candidates` with columns:
#   id uuid default gen_random_uuid(), name text, email text, phone text, score numeric, created_at timestamptz default now()
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: list/delete in /api/admin/candidates (bypass RLS). Optional if RLS allows admin.
SUPABASE_SERVICE_ROLE_KEY=

# Admin console (POST /api/admin/verify) — never commit the real password
ADMIN_CONSOLE_PASSWORD=
